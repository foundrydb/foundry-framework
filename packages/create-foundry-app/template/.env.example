# Injected automatically by `foundry dev` or the FoundryDB platform.
# Do NOT commit real values. Copy to .env.local for manual overrides.

# Postgres connection string
DATABASE_URL=postgresql://foundrydev:foundrydev@localhost:15432/foundrydev

# S3-compatible object storage (MinIO in dev)
S3_ENDPOINT=http://localhost:19000
S3_BUCKET=foundry-dev
S3_ACCESS_KEY=foundrydev
S3_SECRET=foundrydev123

# OIDC issuer for auth
AUTHD_ISSUER_URL=http://localhost:14000

# Platform API (set by foundry deploy; not needed for dev)
# FOUNDRY_API_TOKEN=...
# FOUNDRY_API_URL=https://api.foundrydb.com
